# ================================
# APPLICATION
# ================================
APP_NAME=QuantVision
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=True

# Local service ports
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_PORT=5173

# ================================
# DATA SOURCES
# ================================
# Primary market data source is yfinance and does not require a key.
# Alpha Vantage is optional and only used by endpoints that support it.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Historical download helpers
DATA_START_DATE=2019-01-01
DATA_END_DATE=2024-12-31
ENABLE_SP500=True
ENABLE_RUSSELL2000=False

# ================================
# MODEL AND BACKTEST DEFAULTS
# ================================
DEFAULT_MODEL=xgboost
LOOKBACK_PERIOD=60
TRAIN_TEST_SPLIT=0.8
RISK_FREE_RATE=0.04
INITIAL_CAPITAL=100000
COMMISSION_RATE=0.0
SLIPPAGE_RATE=0.001

# ================================
# AGENT WORKFLOWS
# ================================
# Optional. Only needed if you want CrewAI-backed analysis routes/tools.
ANTHROPIC_API_KEY=your_anthropic_api_key
QUANTVISION_API_URL=http://localhost:8000

# ================================
# DATABASE
# ================================
DB_TYPE=sqlite
SQLITE_DB_PATH=database/stock_data.db

# Optional PostgreSQL / TimescaleDB settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_data
